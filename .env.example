# Optional extra speedtest server. The registry in src/lib/servers.ts always
# contains the production Hostinger backend (https://speed.netspeed.me);
# setting this adds a staging/local server to the pool, and the engine picks
# whichever server answers /ping fastest. The server must expose CORS-enabled
# endpoints:
#   GET  /ping                 -> JSON latency probe
#   GET  /download?size=100MB  -> streams incompressible bytes
#   POST /upload               -> accepts and discards a binary body
# NOTE: NEXT_PUBLIC_* vars are inlined at build time — rebuild after changing.
NEXT_PUBLIC_TEST_SERVER_URL=
